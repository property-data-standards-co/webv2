---
import '../tailwind.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A trust framework enabling standardised, verifiable property information across the UK homebuying process" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | PDTF</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-white text-gray-800 font-sans antialiased">
    <slot name="header">
      <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <div class="flex items-center gap-8">
              <a href="/" class="flex items-center gap-2">
                <span class="text-2xl font-bold text-pdtf-navy">PDTF</span>
              </a>
              <div class="hidden md:flex items-center gap-6">
                <a href="/why" class="text-gray-600 hover:text-pdtf-orange transition-colors">Why PDTF</a>
                <a href="/how-it-works" class="text-gray-600 hover:text-pdtf-orange transition-colors">How It Works</a>
                <a href="/for-industry" class="text-gray-600 hover:text-pdtf-orange transition-colors">For Industry</a>
                <a href="/for-developers" class="text-gray-600 hover:text-pdtf-orange transition-colors">For Developers</a>
                <a href="/about" class="text-gray-600 hover:text-pdtf-orange transition-colors">About</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <a href="https://github.com/Property-Data-Trust-Framework" target="_blank" rel="noopener" class="text-gray-500 hover:text-gray-700">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              </a>
              <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </div>
          <!-- Mobile menu -->
          <div id="mobile-menu" class="hidden md:hidden pb-4">
            <a href="/why" class="block py-2 text-gray-600 hover:text-pdtf-orange">Why PDTF</a>
            <a href="/how-it-works" class="block py-2 text-gray-600 hover:text-pdtf-orange">How It Works</a>
            <a href="/for-industry" class="block py-2 text-gray-600 hover:text-pdtf-orange">For Industry</a>
            <a href="/for-developers" class="block py-2 text-gray-600 hover:text-pdtf-orange">For Developers</a>
            <a href="/about" class="block py-2 text-gray-600 hover:text-pdtf-orange">About</a>
          </div>
        </nav>
      </header>
    </slot>

    <main>
      <slot />
    </main>

    <footer class="bg-pdtf-navy text-white mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-lg font-semibold mb-4">PDTF</h3>
            <ul class="space-y-2 text-gray-300">
              <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
              <li><a href="/why" class="hover:text-white transition-colors">Why PDTF</a></li>
              <li><a href="/how-it-works" class="hover:text-white transition-colors">How It Works</a></li>
              <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-4">Industry</h3>
            <ul class="space-y-2 text-gray-300">
              <li><a href="/for-industry#estate-agents" class="hover:text-white transition-colors">Estate Agents</a></li>
              <li><a href="/for-industry#conveyancers" class="hover:text-white transition-colors">Conveyancers</a></li>
              <li><a href="/for-industry#lenders" class="hover:text-white transition-colors">Lenders</a></li>
              <li><a href="/for-industry#proptech" class="hover:text-white transition-colors">Proptech</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-4">Developers</h3>
            <ul class="space-y-2 text-gray-300">
              <li><a href="/for-developers#getting-started" class="hover:text-white transition-colors">Getting Started</a></li>
              <li><a href="/for-developers#api" class="hover:text-white transition-colors">API Reference</a></li>
              <li><a href="/for-developers#schemas" class="hover:text-white transition-colors">Schemas</a></li>
              <li><a href="https://github.com/Property-Data-Trust-Framework" class="hover:text-white transition-colors">GitHub ↗</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-4">Community</h3>
            <ul class="space-y-2 text-gray-300">
              <li><a href="https://openpropdata.org.uk" target="_blank" class="hover:text-white transition-colors">OPDA ↗</a></li>
              <li><a href="https://github.com/Property-Data-Trust-Framework" target="_blank" class="hover:text-white transition-colors">GitHub ↗</a></li>
              <li><a href="/about#contact" class="hover:text-white transition-colors">Contact</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
          <p>© 2026 Open Property Data Association. PDTF is an open standard.</p>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
