---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="For Industry" description="How PDTF benefits estate agents, conveyancers, lenders, and proptech companies">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-pdtf-navy to-pdtf-navy-light text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">For Industry</h1>
        <p class="text-xl text-gray-200">
          Whether you're an estate agent, conveyancer, lender, or proptech builder — PDTF helps you work faster, reduce costs, and serve customers better.
        </p>
      </div>
    </div>
  </section>

  <!-- Estate Agents -->
  <section id="estate-agents" class="py-20 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-pdtf-orange/10 text-pdtf-orange px-4 py-2 rounded-full text-sm font-medium mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            Estate Agents
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-pdtf-navy mb-6">Reduce fall-throughs, accelerate completions</h2>
          <p class="text-lg text-gray-600 mb-6">
            Collect material information upfront and share it securely with all parties. When issues surface early, they can be resolved before they derail the sale.
          </p>
          
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Upfront material information</h4>
                <p class="text-gray-600 text-sm">Capture and share BASPI data from day one</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Fewer nasty surprises</h4>
                <p class="text-gray-600 text-sm">Issues surfaced before offers are made</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Digital Sale Ready packages</h4>
                <p class="text-gray-600 text-sm">Pre-compiled packs that accelerate the process</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-50 rounded-2xl p-8">
          <h3 class="text-xl font-semibold text-pdtf-navy mb-4">Case Study: Connells Digital Sale Ready</h3>
          <p class="text-gray-600 mb-4">
            Connells have piloted a "Digital Sale Ready" approach using PDTF standards, progressively integrating more data sources and participants.
          </p>
          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-pdtf-orange rounded-full"></div>
              <span>Material Information from day one</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-pdtf-orange rounded-full"></div>
              <span>Digital ID verification</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-pdtf-orange rounded-full"></div>
              <span>Legal info and title deeds</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-pdtf-orange rounded-full"></div>
              <span>Ordered searches upfront</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-pdtf-orange rounded-full"></div>
              <span>PDTF API for case updates</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Conveyancers -->
  <section id="conveyancers" class="py-20 bg-gray-50 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="lg:order-2">
          <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-600 px-4 py-2 rounded-full text-sm font-medium mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
            Conveyancers
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-pdtf-navy mb-6">Structured data, reduced re-keying</h2>
          <p class="text-lg text-gray-600 mb-6">
            Receive standardised property data directly into your case management system. No more re-keying from PDFs or chasing information across multiple channels.
          </p>
          
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Direct CMS integration</h4>
                <p class="text-gray-600 text-sm">Structured JSON data flows straight into your systems</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Early issue visibility</h4>
                <p class="text-gray-600 text-sm">See potential problems before you're deep in the transaction</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Provenance you can trust</h4>
                <p class="text-gray-600 text-sm">Know exactly where each piece of data came from</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="lg:order-1 bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="text-xl font-semibold text-pdtf-navy mb-4">How it works</h3>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 text-blue-600 font-medium">1</div>
              <div>
                <h4 class="font-medium text-pdtf-navy">Receive property pack</h4>
                <p class="text-sm text-gray-600">Standardised data pushed to your CMS via API</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 text-blue-600 font-medium">2</div>
              <div>
                <h4 class="font-medium text-pdtf-navy">Review provenance</h4>
                <p class="text-sm text-gray-600">See trust level for each data element</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 text-blue-600 font-medium">3</div>
              <div>
                <h4 class="font-medium text-pdtf-navy">Subscribe to updates</h4>
                <p class="text-sm text-gray-600">Get notified when new claims are added</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 text-blue-600 font-medium">4</div>
              <div>
                <h4 class="font-medium text-pdtf-navy">Raise enquiries</h4>
                <p class="text-sm text-gray-600">Request clarification through the framework</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lenders -->
  <section id="lenders" class="py-20 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-green-100 text-green-600 px-4 py-2 rounded-full text-sm font-medium mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Lenders
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-pdtf-navy mb-6">Better risk assessment, faster decisions</h2>
          <p class="text-lg text-gray-600 mb-6">
            Access verified property data for more accurate valuations and risk assessments. Reduce fraud through cryptographic provenance.
          </p>
          
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Standardised property data</h4>
                <p class="text-gray-600 text-sm">Consistent formats for automated processing</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Verified valuation inputs</h4>
                <p class="text-gray-600 text-sm">Trusted EPC, searches, and title data</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-pdtf-navy">Fraud reduction</h4>
                <p class="text-gray-600 text-sm">Cryptographic provenance makes tampering evident</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bg-gradient-to-br from-green-50 to-blue-50 rounded-2xl p-8">
          <h3 class="text-xl font-semibold text-pdtf-navy mb-4">Access controls built-in</h3>
          <p class="text-gray-600 mb-6">
            PDTF's permission model ensures lenders only see what they need to see, with role-based access and confidentiality controls.
          </p>
          <div class="bg-white rounded-lg p-4 border border-gray-200">
            <h4 class="font-medium text-pdtf-navy mb-2">Data visibility matrix</h4>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">Property details</span>
                <span class="text-green-600">✓ Public</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">Title information</span>
                <span class="text-green-600">✓ Public</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">EPC & Searches</span>
                <span class="text-green-600">✓ Public</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">AML status</span>
                <span class="text-blue-600">✓ Lender access</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">Participant PII</span>
                <span class="text-orange-600">⚡ Role-restricted</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proptech -->
  <section id="proptech" class="py-20 bg-gray-50 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-600 px-4 py-2 rounded-full text-sm font-medium mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
          Proptech & Integrators
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-pdtf-navy mb-6">One integration, infinite connections</h2>
        <p class="text-lg text-gray-600">
          Build once to the PDTF standard and connect with any participant in the ecosystem. No more point-to-point integrations.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-pdtf-navy mb-2">Single schema</h3>
          <p class="text-gray-600">
            One JSON Schema for property data. Version-controlled and semantically stable. No more parsing different formats from different sources.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-pdtf-navy mb-2">Standard API</h3>
          <p class="text-gray-600">
            REST API with full OpenAPI specification. Well-documented endpoints for reading, writing, and subscribing to property data.
          </p>
        </div>
        
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-pdtf-navy mb-2">Network-agnostic</h3>
          <p class="text-gray-600">
            Works across different orchestration networks. Your integration is portable — not locked to a single infrastructure provider.
          </p>
        </div>
      </div>
      
      <div class="mt-12 text-center">
        <a href="/for-developers" class="btn-primary">View Developer Documentation</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="section-heading">Ready to Get Involved?</h2>
      <p class="text-xl text-gray-600 mb-8">
        Join the growing ecosystem of organisations using PDTF to transform property transactions.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/for-developers" class="btn-primary">Developer Docs</a>
        <a href="/about#contact" class="btn-secondary">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

